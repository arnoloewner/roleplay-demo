{
  "name": "roleplay-demo",
  "description": "Standalone Roleplay Demo - Text-based sales training with AI",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.cjs",
